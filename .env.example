# Required: your own Anthropic API key. Your tokens, your usage.
ANTHROPIC_API_KEY=

# Optional: raises the GitHub API rate limit from 60/hr (unauthenticated) to 5000/hr.
# A fine-grained token with no permissions (public read only) is enough.
GITHUB_TOKEN=

# Model used for summarization. See https://docs.claude.com for current model IDs.
CLAUDE_MODEL=claude-sonnet-5

# Path (inside the container) to your compose files, mounted read-only.
# See docker-compose.example.yml for the matching volume mount.
COMPOSE_ROOT=/compose

# Path (inside the container) to the SQLite database file.
DATA_DIR=/data

TZ=Australia/Sydney

# Shared secret Dockhand's generic webhook must send as a query param (?token=...)
# to trigger an immediate out-of-cycle check. Leave blank to disable the webhook endpoint.
WEBHOOK_TOKEN=

# Notifications — both can be set at once, you'll get both. Leave either blank to skip it.
DISCORD_WEBHOOK_URL=
# Comma-separated Apprise service URLs. See https://github.com/caronc/apprise for the full
# list of supported services and URL formats (Slack, ntfy, email, Telegram, Pushover, etc.)
APPRISE_URLS=

# Base URL this app is reachable at, e.g. http://192.168.4.59:8420. Used to make notification
# links clickable. Optional — notifications still work without it, just without a direct link.
PUBLIC_URL=

# How many registries to check at once.
REGISTRY_CHECK_CONCURRENCY=10

# Log health watcher tuning. The schedule itself is configured from the Settings tab in the
# UI, not here — all three features (Updates, Logs, Compose) start off, and their schedules
# default to following the general schedule until you set something different.
LOG_LOOKBACK_HOURS=24
LOG_MAX_LINES_PER_CONTAINER=5000

# Minimum severity that triggers a Discord/Apprise notification for log/compose findings.
# One of: suggestion, warning, critical. Storage on the dashboard always happens regardless —
# this only gates notifications. Defaults to the most sensitive setting (notify on everything).
MIN_SEVERITY=suggestion
