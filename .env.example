# Required: your own Anthropic API key. Your tokens, your usage.
ANTHROPIC_API_KEY=

# Optional: raises the GitHub API rate limit from 60/hr (unauthenticated) to 5000/hr.
# A fine-grained token with no permissions (public read only) is enough.
GITHUB_TOKEN=

# Model used for summarization. See https://docs.claude.com for current model IDs.
CLAUDE_MODEL=claude-sonnet-5

# How often to run the update check. Cron syntax, evaluated in TZ below.
# Default: once a day at 06:00.
CHECK_SCHEDULE_CRON=0 6 * * *

# Path (inside the container) to your compose files, mounted read-only.
# See docker-compose.example.yml for the matching volume mount.
COMPOSE_ROOT=/compose

# Path (inside the container) to the SQLite database file.
DATA_DIR=/data

TZ=Australia/Sydney

# Shared secret Dockhand's generic webhook must send as a query param (?token=...)
# to trigger an immediate out-of-cycle check. Leave blank to disable the webhook endpoint.
WEBHOOK_TOKEN=
